local function updateFOV()
    local percent = (aimbot.fov - 30) / (200 - 30)
    sliderKnob.Position = UDim2.new(percent, -10, 0.5, -10)
    fovCircle.Size = UDim2.new(0, aimbot.fov * 2, 0, aimbot.fov * 2)
    fovCircle.Position = UDim2.new(0.5, -aimbot.fov, 0.5, -aimbot.fov)
    fovLabel.Text = "FOV: " .. aimbot.fov
end

-- Slider Logic
local dragging = false
sliderBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
    end
end)

game:GetService("UserInputService").InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

game:GetService("RunService").RenderStepped:Connect(function()
    if dragging then
        local mouseX = game:GetService("UserInputService"):GetMouseLocation().X
        local barPos = sliderBar.AbsolutePosition.X
        local barSize = sliderBar.AbsoluteSize.X
        local percent = math.clamp((mouseX - barPos) / barSize, 0, 1)
        aimbot.fov = math.floor(30 + percent * (200 - 30))
        updateFOV()
    end
end)

